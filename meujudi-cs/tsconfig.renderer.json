{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "plugins": [{ "name": "next" }]
  },
  "include": ["src/renderer/**/*", "src/shared/**/*", "src/shared/**/*.d.ts", "next-env.d.ts"],
  "exclude": ["node_modules", "dist", "src/main/**/*", "src/extractor/**/*", "src/preload/**/*"]
}
