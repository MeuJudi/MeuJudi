{
  "name": "meujudi-cs",
  "version": "0.2.0",
  "description": "MeuJudi CS — Cert Service. App desktop (Electron) que conecta o MeuJudi Web ao PJe via cert. A1 ou gov.br.",
  "main": "dist/main/index.js",
  "author": "Caio",
  "license": "UNLICENSED",
  "private": true,
  "productName": "MeuJudi CS",
  "scripts": {
    "dev": "concurrently \"npm:dev:main\" \"npm:dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "cd src/renderer && next dev -p 3000",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "cd src/renderer && next build && node scripts/fix-static-paths.cjs",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron .",
    "lint": "eslint --ext .ts,.tsx src/",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p src/renderer/tsconfig.json",
    "test": "node tests/validate-pre-build.js && node tests/confirmadv-helpers.test.js",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "pack": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "node-cron": "^3.0.3",
    "node-machine-id": "^1.1.12",
    "pdf-parse": "^1.1.1",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.5",
    "eslint": "^9.10.0",
    "next": "^14.2.0",
    "postcss": "^8.4.49",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.meujudi.cs",
    "productName": "MeuJudi CS",
    "copyright": "Copyright © 2026 Caio",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "artifactName": "MeuJudi-CS-Setup-v${version}.${ext}",
    "files": [
      "dist/**/*",
      "src/renderer/out/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "MeuJudi",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "MeuJudi CS"
    }
  }
}
